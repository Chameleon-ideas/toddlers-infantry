---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm';
import { getSiteSettings, getContactPage, urlFor } from '../utils/sanity';

const [siteSettings, pageData] = await Promise.all([
  getSiteSettings(),
  getContactPage(),
]);

// ── Logo / Navbar ─────────────────────────────────────────────────────────────
const logoUrl = siteSettings?.logo
  ? urlFor(siteSettings.logo).width(300).auto('format').url()
  : null;
const logoAlt = siteSettings?.logo?.alt || "Toddler's Infantry Logo";

// ── Footer ────────────────────────────────────────────────────────────────────
const footerProps = {
  logoUrl:       logoUrl ?? undefined,
  logoAlt,
  tagline:       siteSettings?.footerTagline      || undefined,
  links:         siteSettings?.footerLinks?.length ? siteSettings.footerLinks : undefined,
  email:         siteSettings?.contactEmail        || undefined,
  phone:         siteSettings?.contactPhone        || undefined,
  location:      siteSettings?.contactLocation     || undefined,
  copyrightName: siteSettings?.footerCopyrightName || undefined,
};

// ── Hero ──────────────────────────────────────────────────────────────────────
const heroHeading = pageData?.heroHeading || 'Get in Touch';
const heroSubtext  = pageData?.heroSubtext  || "Ready to start your journey with Toddler's Infantry? Fill out the form below to request an appointment or inquiry.";

// ── Contact details panel ─────────────────────────────────────────────────────
const detailsHeading = pageData?.detailsHeading || 'Contact Details';
const detailsSubtext  = pageData?.detailsSubtext  || 'If you have urgent questions, feel free to reach out directly via email or phone.';

const contactEmail    = siteSettings?.contactEmail    || 'care@toddlersinfantry.com';
const contactPhone    = siteSettings?.contactPhone    || '(555) 123-4567';
const contactLocation = siteSettings?.contactLocation || 'Alberta, Canada';

// ── Booking notice ────────────────────────────────────────────────────────────
const bookingNoticeHeading = pageData?.bookingNoticeHeading || 'Note on Payments';
const bookingNoticeBody    = pageData?.bookingNoticeBody
  || 'Appointments require a $25 booking fee. Details for offline payment will be sent upon form submission by Kareen.';
---

<Layout title="Book an Appointment | Toddler's Infantry">
  <Navbar logoUrl={logoUrl ?? undefined} logoAlt={logoAlt} />
  
  <main class="contact-ultra-fix">
    <section class="mega-hero">
      <div class="container">
        <h1>{heroHeading}</h1>
        <p>{heroSubtext}</p>
      </div>
    </section>

    <section class="content-body">
      <div class="container">
        <div class="split-grid">
          <div class="details-pane">
            <h2>{detailsHeading}</h2>
            <p class="subtext">{detailsSubtext}</p>
            
            <div class="contact-items">
              {contactEmail && (
                <div class="item">
                  <span class="label">Email</span>
                  <span class="value">{contactEmail}</span>
                </div>
              )}
              {contactPhone && (
                <div class="item">
                  <span class="label">Phone</span>
                  <span class="value">{contactPhone}</span>
                </div>
              )}
              {contactLocation && (
                <div class="item">
                  <span class="label">Location</span>
                  <span class="value">{contactLocation}</span>
                </div>
              )}
            </div>

            <div class="booking-notice">
              <h4>{bookingNoticeHeading}</h4>
              <p>{bookingNoticeBody}</p>
            </div>
          </div>

          <div class="form-pane">
            <div class="card">
              <ContactForm client:load />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer {...footerProps} />
</Layout>

<style is:global>
  .contact-ultra-fix {
    background: #FDFBF8 !important;
    min-height: 100vh;
    padding-bottom: 80px;
  }

  .mega-hero {
    background: #E84164 !important;
    color: #FFFFFF !important;
    text-align: center;
    padding: 140px 0 80px !important;
  }

  .mega-hero h1 {
    font-size: var(--text-5xl) !important;
    margin-bottom: 10px !important;
    color: #FFFFFF !important;
  }

  .mega-hero p {
    font-size: var(--text-md) !important;
    max-width: 600px;
    margin: 0 auto !important;
    color: #FFFFFF !important;
    opacity: 0.9;
  }

  .content-body {
    margin-top: -50px !important;
    position: relative;
    z-index: 10;
  }

  .split-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 60px;
    align-items: start;
  }

  .details-pane {
    padding-top: 60px;
  }

  .details-pane h2 {
    font-size: var(--text-3xl);
    color: #E84164;
    margin-bottom: 20px;
  }

  .details-pane .subtext {
    color: #000000 !important;
    font-weight: 500;
  }

  .contact-items {
    margin: 40px 0;
  }

  .item {
    margin-bottom: 30px;
  }

  .item .label {
    display: block;
    font-size: var(--text-xs);
    text-transform: uppercase;
    color: #E84164;
    font-weight: 700;
    margin-bottom: 5px;
  }

  .item .value {
    font-size: var(--text-xl);
    font-weight: 700;
    color: #000000 !important;
  }

  .booking-notice {
    background: #F5F1E9;
    padding: 30px;
    border-radius: 20px;
    border-left: 6px solid #69217A;
  }

  .booking-notice h4 {
    margin-bottom: 10px;
    color: #69217A;
  }

  .booking-notice p {
    color: #000000 !important;
  }

  .form-pane .card {
    background: #FFFFFF !important;
    padding: 60px !important;
    border-radius: 40px;
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.1) !important;
  }

  /* PREMIUM FORM ELEMENTS */
  .form-pane input, 
  .form-pane select, 
  .form-pane textarea {
    width: 100% !important;
    padding: 18px 20px !important;
    border: 1.5px solid #E5E7E2 !important;
    background: #FCFCFC !important;
    border-radius: 16px !important;
    font-size: 1rem !important;
    color: #000000 !important;
    margin-bottom: 20px !important;
    transition: all 0.3s ease !important;
  }

  .form-pane input:focus, 
  .form-pane select:focus, 
  .form-pane textarea:focus {
    outline: none !important;
    border-color: #E84164 !important;
    background: #FFFFFF !important;
    box-shadow: 0 0 0 4px rgba(232, 65, 100, 0.1) !important;
  }

  .form-pane button[type="submit"],
  .form-pane .submit-btn {
    background: #E84164 !important;
    color: #FFFFFF !important;
    width: 100% !important;
    padding: 20px !important;
    border: none !important;
    border-radius: 50px !important;
    font-weight: 700 !important;
    font-size: var(--text-md) !important;
    cursor: pointer !important;
    transition: all 0.3s ease !important;
    box-shadow: 0 10px 25px rgba(232, 65, 100, 0.25) !important;
    margin-top: 10px !important;
  }

  .form-pane button[type="submit"]:hover,
  .form-pane .submit-btn:hover {
    background: #69217A !important; /* Royal Purple on hover */
    transform: translateY(-2px) !important;
  }

  /* FORCE BLACK LABELS GLOBALLY FOR THIS PAGE */
  html body .form-pane label,
  html body .form-pane .label {
    color: #000000 !important;
    font-weight: 800 !important;
    opacity: 1 !important;
    display: block !important;
    margin-bottom: 10px !important;
    font-size: var(--text-sm) !important;
  }

  @media (max-width: 992px) {
    .split-grid {
      grid-template-columns: 1fr;
    }
    .content-body {
      margin-top: 0 !important;
      padding-top: 40px;
    }
    .details-pane {
      padding-top: 0;
      text-align: center;
    }
  }

  @media (max-width: 768px) {
    .mega-hero {
      padding: 100px 0 60px !important;
    }
    .form-pane .card {
      padding: 40px 24px !important;
      border-radius: 24px;
    }
    .contact-items {
      margin: 24px 0;
    }
    .item {
      margin-bottom: 20px;
    }
  }

  @media (max-width: 480px) {
    .mega-hero {
      padding: 80px 0 40px !important;
    }
    .form-pane .card {
      padding: 24px 16px !important;
      border-radius: 20px;
    }
    .booking-notice {
      padding: 20px;
    }
  }
</style>
