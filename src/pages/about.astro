---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/common/Button.astro";
import { getSiteSettings, getAboutPage, urlFor } from "../utils/sanity";

const [siteSettings, cms] = await Promise.all([
  getSiteSettings(),
  getAboutPage(),
]);

// ── Logo / Navbar ─────────────────────────────────────────────────────────────
const logoUrl = siteSettings?.logo
  ? urlFor(siteSettings.logo).width(300).auto("format").url()
  : null;
const logoAlt = siteSettings?.logo?.alt || "Toddler's Infantry Logo";

// ── Footer ────────────────────────────────────────────────────────────────────
const footerProps = {
  logoUrl: logoUrl ?? undefined,
  logoAlt,
  tagline: siteSettings?.footerTagline || undefined,
  links: siteSettings?.footerLinks?.length
    ? siteSettings.footerLinks
    : undefined,
  email: siteSettings?.contactEmail || undefined,
  phone: siteSettings?.contactPhone || undefined,
  location: siteSettings?.contactLocation || undefined,
  copyrightName: siteSettings?.footerCopyrightName || undefined,
};

// ── Page Header ───────────────────────────────────────────────────────────────
const heroHeading = cms?.heroHeading || "Our Story & Approach";
const heroSubtext =
  cms?.heroSubtext ||
  "Dedicated to providing the most nurturing and professional newborn care in Alberta.";

// ── About Content ─────────────────────────────────────────────────────────────
const aboutHeading =
  cms?.aboutHeading || "Nurturing the Future, One Small Step at a Time";
const aboutParagraph1 =
  cms?.aboutParagraph1 ||
  "At Toddler's Infantry, we believe that the first months and years of a child's life are the most critical. Founded by Kareen, our agency was born out of a passion for supporting new families through the beautiful yet challenging transition of early parenthood.";
const aboutParagraph2 =
  cms?.aboutParagraph2 ||
  'Our approach is centered on trust, professionalism, and personalized care. We don\'t just provide "babysitting"; we provide specialized newborn care that focuses on developmental milestones, sleep health, and physical support for both the baby and the parents.';

// ── About Image ───────────────────────────────────────────────────────────────
const aboutImageUrl = cms?.aboutImage
  ? urlFor(cms.aboutImage)
      .width(600)
      .height(600)
      .fit("crop")
      .auto("format")
      .url()
  : null;
const aboutImageAlt = cms?.aboutImage?.alt || "Caregiver with baby";
// ── Approach Items ────────────────────────────────────────────────────────────
const approachItems =
  cms?.approachItems?.length > 0
    ? cms.approachItems
    : [
        {
          icon: "✨",
          heading: "Trust & Safety",
          description:
            "All our caregivers are highly experienced, certified, and background-checked.",
        },
        {
          icon: "🌿",
          heading: "Holistic Well-being",
          description:
            "Supporting emotional health and physical development through gentle techniques.",
        },
      ];

// ── Team / Bio ────────────────────────────────────────────────────────────────
const teamSectionHeading = cms?.teamSectionHeading || "Meet Kareen";
const teamSectionSubtext =
  cms?.teamSectionSubtext || "The vision and heart behind Toddler's Infantry.";
const bioText =
  cms?.bioText ||
  "Kareen’s foundation in newborn care is deeply rooted in a legacy of excellence. Her journey began in Jamaica, where she was raised in a family devoted to childcare. Guided by her mother with over 25 years of dedicated childcare experience, Kareen was introduced early to the art and responsibilities of caring for infants. By the age of 15, she was already working within her family’s established daycare, supporting the care of newborn and toddlers, including providing trusted overnight care for families with demanding schedules.\n\nThis early, hands-on experience shaped not only her skill, but her intuitive, calm approach to caring for infants and supporting parents during their most delicate transition. Today Kareen brings that same level of discretion, expertise, and heartfelt care to every family she serves.";
const approachHeading = "Our Approach";
const approachText =
  "We understand that every family is unique. Our care is thoughtfully tailored to meet your households needs, offering:";
const approachBullets = [
  "Discreet, professional overnight newborn care",
  "Gentle sleep shaping and guidance",
  "Support for first-time parents and growing families",
  "Specialized care for twins and high-demand schedules",
];
const approachFooter =
  "Our goal is simple: to ensure your baby is nurtured with excellence while you experience the rest and reassurance you deserve.";

const standardOfCareTitle = "A Standard of Care You Can Trust";
const standardOfCareText =
  "At Toddler's Infantry, we are committed to delivering a level of service that reflects professionalism, warmth, and reliability. Families choose us not only for our experience, but for our ability to create a peaceful, supportive environment during one of life’s most important transitions.";
const bioCtaLabel = cms?.bioCtaLabel || "Book a consultation with Kareen";
const bioCtaUrl = cms?.bioCtaUrl || "/contact";
---

<Layout title="About Us | Toddler's Infantry">
  <Navbar logoUrl={logoUrl ?? undefined} logoAlt={logoAlt} />

  <main>
    <!-- PAGE HEADER -->
    <section class="page-header">
      <div class="container">
        <h1 class="reveal">{heroHeading}</h1>
        <p class="reveal">{heroSubtext}</p>
      </div>
    </section>

    <!-- ABOUT CONTENT -->
    <section class="about-content">
      <div class="container">
        <div class="about-grid">
          <div class="about-text reveal">
            <h2>{aboutHeading}</h2>
            <p>{aboutParagraph1}</p>
            <p>{aboutParagraph2}</p>

            <div class="approach-list">
              {
                approachItems.map((item: any) => (
                  <div class="approach-item">
                    <span class="icon">{item.icon}</span>
                    <div>
                      <h4>{item.heading}</h4>
                      <p>{item.description}</p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="about-image reveal">
            <div class="image-accent">
              {
                aboutImageUrl ? (
                  <img src={aboutImageUrl} alt={aboutImageAlt} loading="lazy" />
                ) : (
                  <img src="/about.png" alt={aboutImageAlt} loading="lazy" />
                )
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TEAM / BIO SECTION -->
    <section class="team-section">
      <div class="container">
        <div class="section-title reveal text-center about-text">
          <h2>{teamSectionHeading}</h2>
          <p>{teamSectionSubtext}</p>
        </div>

        <div class="bio-card reveal">
          <div class="bio-text">
            {bioText.split("\n\n").map((p: string) => <p>{p}</p>)}

            <div style="margin-top: 2rem;">
              <Button href={bioCtaUrl}>{bioCtaLabel}</Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- OUR APPROACH SECTION -->
    <section class="section-padding bg-light">
      <div class="container">
        <div class="section-title reveal text-center mx-auto-800">
          <h2>{approachHeading}</h2>
          <p class="mb-2">
            {approachText}
          </p>
        </div>
        <div class="reveal mx-auto-800">
          <ul
            style="list-style-type: none; padding: 0; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 1rem;"
          >
            {
              approachBullets.map((bullet: string) => (
                <li style="background: white; padding: 1.5rem; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); display: flex; align-items: center; gap: 1rem;">
                  <span style="color: var(--color-primary); font-size: 1.5rem;">
                    ✓
                  </span>
                  <span style="font-weight: 500;">{bullet}</span>
                </li>
              ))
            }
          </ul>
          <p
            style="text-align: center; font-weight: 600; color: var(--color-primary); font-size: 1.1rem;"
          >
            {approachFooter}
          </p>
        </div>
      </div>
    </section>

    <!-- STANDARD OF CARE SECTION -->
    <section class="section-padding">
      <div class="container">
        <div class="section-title reveal text-center">
          <h2>{standardOfCareTitle}</h2>
        </div>
        <div class="reveal mx-auto-800 text-center standard-text">
          <p>{standardOfCareText}</p>
        </div>
      </div>
    </section>
  </main>

  <Footer {...footerProps} />
</Layout>

<style>
  .mx-auto-800 {
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  .mb-2 {
    margin-bottom: 2rem;
  }
  .standard-text {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .about-content {
    padding: var(--space-xl) 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .about-text h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-md);
    color: var(--color-primary);
  }

  .about-text p {
    font-size: var(--text-base);
    color: #444;
    margin-bottom: var(--space-md);
  }

  .approach-list {
    margin-top: var(--space-lg);
  }

  .approach-item {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .approach-item .icon {
    font-size: var(--text-xl);
    background: white;
    width: 50px;
    height: 50px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
  }

  .about-image {
    display: flex;
    justify-content: center;
  }

  .image-accent {
    background: var(--color-primary);
    padding: var(--space-xl);
    border-radius: 30% 70% 30% 70% / 50% 50% 50% 50%;
  }

  .image-accent img {
    max-width: 300px;
    height: auto;
    display: block;
  }

  .text-center {
    text-align: center;
    padding: 20px;
  }

  .text-green {
    color: #6b7c67;
  }

  .team-section {
    padding: var(--space-xl) 0;
    background: var(--color-bg-light);
  }

  .bio-card {
    background: white;
    padding: var(--space-xl);
    border-radius: 40px;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.05);
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .bio-text p {
    font-size: var(--text-md);
    color: #000000;
    margin-bottom: var(--space-lg);
  }

  /* ── Tablet ── */
  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .about-image {
      order: -1;
    }
    .approach-item {
      justify-content: center;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .about-content {
      padding: var(--space-lg) 0;
    }

    .about-text p {
      font-size: var(--text-base);
    }

    .approach-list {
      margin-top: var(--space-md);
    }

    .approach-item {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--space-sm);
    }

    .approach-item .icon {
      width: 44px;
      height: 44px;
      font-size: var(--text-lg);
    }

    .image-accent {
      padding: var(--space-lg);
      border-radius: 30px;
    }

    .image-accent img {
      max-width: 200px;
    }

    .team-section {
      padding: var(--space-lg) 0;
    }

    .bio-card {
      padding: var(--space-lg) var(--space-md);
      border-radius: 24px;
    }

    .bio-text p {
      font-size: var(--text-base);
      margin-bottom: var(--space-md);
    }
  }

  /* ── Small mobile ── */
  @media (max-width: 480px) {
    .about-content {
      padding: var(--space-md) 0;
    }

    .bio-card {
      padding: var(--space-md);
      border-radius: 20px;
    }

    .image-accent {
      padding: var(--space-md);
    }

    .image-accent img {
      max-width: 160px;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const reveals = document.querySelectorAll(".reveal");

    gsap.set(reveals, { opacity: 0, y: 20 });

    reveals.forEach((el) => {
      gsap.to(el, {
        scrollTrigger: {
          trigger: el,
          start: "top 95%",
        },
        y: 0,
        opacity: 1,
        duration: 1,
        ease: "power3.out",
        clearProps: "all",
      });
    });
  });
</script>
