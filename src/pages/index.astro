---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Button from "../components/common/Button.astro";
import {
  getServices,
  getTestimonials,
  getFaqItems,
  getProcessSteps,
  getHomePage,
  getSiteSettings,
  urlFor,
} from "../utils/sanity";

const [fetchedServices, fetchedTestimonials, fetchedFaq, fetchedSteps, cms, siteSettings] =
  await Promise.all([
    getServices(),
    getTestimonials(),
    getFaqItems(),
    getProcessSteps(),
    getHomePage(),
    getSiteSettings(),
  ]);

// ── Image URLs ────────────────────────────────────────────────────────────────
const logoUrl = siteSettings?.logo
  ? urlFor(siteSettings.logo).width(300).auto('format').url()
  : null;
const logoAlt = siteSettings?.logo?.alt || "Toddler's Infantry Logo";

const heroImageUrl = cms?.heroImage
  ? urlFor(cms.heroImage).width(800).height(800).fit('crop').auto('format').url()
  : null;
const heroImageAlt = cms?.heroImage?.alt || 'Baby Care';

// ── Footer props ──────────────────────────────────────────────────────────────
const footerProps = {
  logoUrl:       logoUrl ?? undefined,
  logoAlt,
  tagline:       siteSettings?.footerTagline       || undefined,
  links:         siteSettings?.footerLinks?.length  ? siteSettings.footerLinks : undefined,
  email:         siteSettings?.contactEmail         || undefined,
  phone:         siteSettings?.contactPhone         || undefined,
  location:      siteSettings?.contactLocation      || undefined,
  copyrightName: siteSettings?.footerCopyrightName  || undefined,
};

// ── Hero ──────────────────────────────────────────────────────────────────────
const heroHeadingRaw = cms?.heroHeading || "Nurturing Your | Little Wonders";
// Split on | so editors can control line break
const [heroLine1, heroLine2] = heroHeadingRaw.includes("|")
  ? heroHeadingRaw.split("|").map((s: string) => s.trim())
  : [heroHeadingRaw, null];

const heroSubtext =
  cms?.heroSubtext ||
  "Professional, high-end newborn and infant care tailored to your family's needs. Trustworthy support for your baby's first steps.";

const heroCtaPrimary    = cms?.heroCtaPrimary    || "Book an Appointment";
const heroCtaPrimaryUrl = cms?.heroCtaPrimaryUrl || "/contact";
const heroCtaSecondary    = cms?.heroCtaSecondary    || "Explore Services";
const heroCtaSecondaryUrl = cms?.heroCtaSecondaryUrl || "/services";

// ── Sections ─────────────────────────────────────────────────────────────────
const servicesSectionTitle   = cms?.servicesSectionTitle   || "Our Excellence";
const servicesSectionSubtext = cms?.servicesSectionSubtext || "We provide specialized care that goes beyond just watching your baby.";

const processSectionTitle   = cms?.processSectionTitle   || "How It Works";
const processSectionSubtext = cms?.processSectionSubtext || "A simple, stress-free process to get the care your family deserves.";

const testimonialsSectionTitle   = cms?.testimonialsSectionTitle   || "From Our Families";
const testimonialsSectionSubtext = cms?.testimonialsSectionSubtext || "Join the many Alberta families who have found peace of mind with us.";

const faqSectionTitle   = cms?.faqSectionTitle   || "Common Questions";
const faqSectionSubtext = cms?.faqSectionSubtext || "Everything you need to know about our nanny and newborn services.";

const ctaHeading     = cms?.ctaHeading     || "Ready to give your baby the best care?";
const ctaSubtext     = cms?.ctaSubtext     || "Schedule a consultation with Kareen today and experience the Toddler's Infantry difference.";
const ctaButtonLabel = cms?.ctaButtonLabel || "Start Your Journey";
const ctaButtonUrl   = cms?.ctaButtonUrl   || "/contact";

// ── Repeatable content ────────────────────────────────────────────────────────
const services =
  fetchedServices.length > 0
    ? fetchedServices
    : [
        {
          title: "Newborn Care",
          icon: "👶",
          description: "Expert night and day care for your little ones.",
        },
        {
          title: "Sleep Training",
          icon: "🌙",
          description:
            "Gentle methods to help your baby sleep through the night.",
        },
        {
          title: "Postpartum Support",
          icon: "🫂",
          description: "Emotional and physical support for new mothers.",
        },
      ];

const testimonials =
  fetchedTestimonials.length > 0
    ? fetchedTestimonials
    : [
        {
          quote:
            "Kareen was a lifesaver for our firstborn. Her gentle approach to sleep training worked wonders in just a week!",
          author: "Sarah & James",
          location: "Calgary",
        },
        {
          quote:
            "Highly professional and incredibly nurturing. We felt 100% confident leaving our newborn in their hands.",
          author: "Michael T.",
          location: "Edmonton",
        },
      ];

const faqItems =
  fetchedFaq.length > 0
    ? fetchedFaq
    : [
        {
          question: "Is Kareen involved in every case?",
          answer:
            "Yes, Kareen personally oversees every care plan and conducts initial consultations to ensure the highest standards.",
        },
        {
          question: "Do you provide overnight support?",
          answer:
            "Absolutely. We offer specialized overnight newborn care to help parents get the rest they need while ensuring the baby is safe and fed.",
        },
        {
          question: "How do payments work?",
          answer:
            "We handle all payments offline. A $25 scheduling fee is required to book, with the remainder settled via direct invoice.",
        },
      ];

const processSteps =
  // 1. Inline steps inside Home Page document (preferred — edited in one place)
  (cms?.processSteps?.length > 0)
    ? cms.processSteps
  // 2. Fallback: old separate processStep documents
  : fetchedSteps.length > 0
    ? fetchedSteps
  // 3. Hardcoded fallback (shown when Sanity has nothing at all)
    : [
        {
          stepNumber: "01",
          title: "Initial Consultation",
          description:
            "We speak with you to understand your baby's current routine and your specific needs.",
        },
        {
          stepNumber: "02",
          title: "Custom Care Plan",
          description:
            "Kareen designs a personalized care or sleep training strategy for your family.",
        },
        {
          stepNumber: "03",
          title: "Dedicated Support",
          description:
            "Our expert team begins the care journey, providing continuous support and guidance.",
        },
      ];
---

<Layout title="Toddler's Infantry | Premium Newborn Care">
  <Navbar logoUrl={logoUrl ?? undefined} logoAlt={logoAlt} />

  <main>
    <!-- HERO SECTION -->
    <section class="hero">
      <div class="container hero-container">
        <div class="hero-content">
          <h1 class="animate-up">
            {heroLine1}{heroLine2 ? <Fragment><br /><span class="text-accent">{heroLine2}</span></Fragment> : ""}
          </h1>
          <p class="animate-up delay-1">{heroSubtext}</p>
          <div class="hero-btns animate-up delay-2">
            <Button href={heroCtaPrimaryUrl}>{heroCtaPrimary}</Button>
            <Button href={heroCtaSecondaryUrl} variant="outline">{heroCtaSecondary}</Button>
          </div>
        </div>
        <div class="hero-image animate-fade">
          <div class="image-wrapper">
            {
              heroImageUrl
                ? <img src={heroImageUrl} alt={heroImageAlt} class="hero-img-main" />
                : <img src="/red-logo.svg" alt={heroImageAlt} class="hero-img-main theme-logo" />
            }
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES PREVIEW -->
    <section class="services-preview section-padding">
      <div class="container">
        <div class="section-title reveal">
          <h2>{servicesSectionTitle}</h2>
          <p>{servicesSectionSubtext}</p>
        </div>

        <div class="services-grid">
          {
            services.map((service, index) => (
              <div
                class="service-card reveal"
                style={`--delay: ${index * 0.2}s`}
              >
                <div class="service-icon">{service.icon}</div>
                <h3>{service.title}</h3>
                <p>{service.description || service.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- PROCESS SECTION -->
    <section class="process section-padding bg-light">
      <div class="container">
        <div class="section-title reveal">
          <h2>{processSectionTitle}</h2>
          <p>{processSectionSubtext}</p>
        </div>
        <div class="process-grid">
          {
            processSteps.map((step) => (
              <div class="process-item reveal">
                <span class="step-number">{step.stepNumber}</span>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="testimonials section-padding">
      <div class="container">
        <div class="section-title reveal">
          <h2>{testimonialsSectionTitle}</h2>
          <p>{testimonialsSectionSubtext}</p>
        </div>
        <div class="testimonials-grid">
          {
            testimonials.map((t) => (
              <div class="testimonial-card reveal">
                <p>"{t.quote}"</p>
                <div class="author">
                  - {t.author}
                  {t.location ? `, ${t.location}` : ""}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="faq section-padding bg-light">
      <div class="container">
        <div class="section-title reveal">
          <h2>{faqSectionTitle}</h2>
          <p>{faqSectionSubtext}</p>
        </div>
        <div class="faq-list">
          {
            faqItems.map((item) => (
              <div class="faq-item reveal">
                <h3>{item.question}</h3>
                <p>{item.answer}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA SECTION -->
    <section class="cta-section reveal section-padding">
      <div class="container">
        <div class="cta-box">
          <h2>{ctaHeading}</h2>
          <p>{ctaSubtext}</p>
          <div class="cta-btn">
            <Button href={ctaButtonUrl} variant="secondary">{ctaButtonLabel}</Button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer {...footerProps} />
</Layout>

<style>
  /* HERO */
  .hero {
    padding: calc(var(--navbar-height) + var(--space-lg)) 0 var(--space-xl);
    background: linear-gradient(
      135deg,
      var(--color-secondary) 0%,
      #ffffff 100%
    );
    overflow: hidden;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .hero-content h1 {
    font-size: var(--text-hero);
    margin-bottom: var(--space-md);
    color: #000000;
    line-height: 1.1;
  }

  .text-accent {
    color: var(--color-accent);
  }

  .hero-content p {
    font-size: var(--text-lg);
    color: #444;
    margin-bottom: var(--space-lg);
    max-width: 600px;
  }

  .hero-btns {
    display: flex;
    gap: var(--space-md);
  }

  .hero-image {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .image-wrapper {
    width: 100%;
    max-width: 500px;
    aspect-ratio: 1;
    background: var(--color-secondary);
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    animation: blob 10s infinite alternate;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-img-main {
    width: 60%;
    height: auto;
    object-fit: contain;
  }

  @keyframes blob {
    0% {
      border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    }
    100% {
      border-radius: 70% 30% 30% 70% / 70% 70% 30% 30%;
    }
  }

  /* SERVICES PREVIEW */
  .services-preview {
    padding: var(--space-xl) 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .section-title h2 {
    font-size: var(--text-4xl);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
    align-items: stretch;
  }

  .service-card {
    padding: var(--space-lg) var(--space-md);
    background: var(--color-secondary);
    border-radius: 30px;
    text-align: center;
    transition: transform 0.5s var(--transition-smooth);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 350px;
  }

  .service-card:hover {
    transform: translateY(-10px);
    background: white;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
  }

  .service-icon {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-md);
  }

  /* GENERAL */
  .bg-light {
    background: var(--color-bg-light);
  }

  /* PROCESS */
  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-xl);
    text-align: center;
  }

  .process-item {
    position: relative;
    padding: var(--space-lg);
  }

  .step-number {
    font-size: clamp(3rem, 8vw, 5rem);
    font-family: var(--font-heading);
    color: var(--color-accent);
    opacity: 0.15;
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 0;
  }

  .process-item h3 {
    position: relative;
    z-index: 1;
    margin-bottom: var(--space-sm);
  }

  /* TESTIMONIALS */
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .testimonial-card {
    background: white;
    padding: var(--space-lg);
    border-radius: 30px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    border-left: 4px solid var(--color-primary);
  }

  .testimonial-card p {
    font-style: italic;
    font-size: var(--text-md);
    margin-bottom: var(--space-sm);
  }

  .testimonial-card .author {
    font-weight: 600;
    color: var(--color-primary);
  }

  /* FAQ */
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .faq-item {
    background: white;
    padding: var(--space-md) var(--space-lg);
    border-radius: 20px;
  }

  .faq-item h3 {
    font-size: var(--text-xl);
    margin-bottom: 8px;
    color: var(--color-primary);
  }

  /* CTA SECTION */
  .cta-section {
    padding-bottom: var(--space-xl);
  }

  .cta-box {
    background: var(--color-primary); /* Deep Forest Sage */
    padding: var(--space-xl) var(--space-lg);
    border-radius: 40px;
    text-align: center;
    color: white;
    box-shadow: 0 30px 60px rgba(107, 124, 103, 0.25);
    position: relative;
    overflow: hidden;
  }

  .cta-box h2 {
    font-size: var(--text-4xl);
    color: white;
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .cta-box p {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-lg);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btn {
    display: flex;
    justify-content: center;
  }

  /* TABLET */
  @media (max-width: 992px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-content p {
      margin: 0 auto var(--space-lg);
    }
    .hero-btns {
      justify-content: center;
    }
    .hero-image {
      order: -1;
    }
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
    .cta-box {
      padding: var(--space-lg) var(--space-md);
    }
  }

  /* MOBILE ≤ 480px */
  @media (max-width: 480px) {
    .hero-btns {
      flex-direction: column;
      align-items: center;
    }
    .service-card {
      min-height: auto;
      padding: var(--space-md);
    }
    .process-item {
      padding: var(--space-md) var(--space-sm);
    }
    .faq-item {
      padding: var(--space-md);
    }
    .cta-box {
      padding: var(--space-md) var(--space-sm);
      border-radius: 24px;
    }
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    // Hero Animations
    gsap.from(".animate-up", {
      y: 50,
      opacity: 0,
      duration: 1,
      stagger: 0.2,
      ease: "power4.out",
    });

    gsap.from(".animate-fade", {
      opacity: 0,
      duration: 1.5,
      delay: 0.5,
      ease: "power2.out",
    });

    // Reveal on Scroll
    const reveals = document.querySelectorAll(".reveal");

    // Hide initially via JS for animation
    gsap.set(reveals, { opacity: 0, y: 30 });

    reveals.forEach((el) => {
      gsap.to(el, {
        scrollTrigger: {
          trigger: el,
          start: "top 90%",
        },
        y: 0,
        opacity: 1,
        duration: 1,
        ease: "power3.out",
        clearProps: "all", // Clean up after animation
      });
    });
  });
</script>
