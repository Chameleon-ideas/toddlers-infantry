---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/common/Button.astro';

const services = [
  { title: 'Newborn Care', icon: '👶', desc: 'Expert night and day care for your little ones.' },
  { title: 'Sleep Training', icon: '🌙', desc: 'Gentle methods to help your baby sleep through the night.' },
  { title: 'Postpartum Support', icon: '🫂', desc: 'Emotional and physical support for new mothers.' },
];
---

<Layout title="Toddler's Infantry | Premium Newborn Care">
  <Navbar />
  
  <main>
    <!-- HERO SECTION -->
    <section class="hero">
      <div class="container hero-container">
        <div class="hero-content">
          <h1 class="animate-up">Nurturing Your <br/><span class="text-accent">Little Wonders</span></h1>
          <p class="animate-up delay-1">Professional, high-end newborn and infant care tailored to your family's needs. Trustworthy support for your baby's first steps.</p>
          <div class="hero-btns animate-up delay-2">
            <Button href="/contact">Book an Appointment</Button>
            <Button href="/services" variant="outline">Explore Services</Button>
          </div>
        </div>
        <div class="hero-image animate-fade">
          <div class="image-wrapper">
             <img src="/logo.png" alt="Baby Care" class="hero-img-main" />
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES PREVIEW -->
    <section class="services-preview section-padding">
      <div class="container">
        <div class="section-title reveal">
          <h2>Our Excellence</h2>
          <p>We provide specialized care that goes beyond just watching your baby.</p>
        </div>
        
        <div class="services-grid">
          {services.map((service, index) => (
            <div class="service-card reveal" style={`--delay: ${index * 0.2}s`}>
              <div class="service-icon">{service.icon}</div>
              <h3>{service.title}</h3>
              <p>{service.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- PROCESS SECTION -->
    <section class="process section-padding bg-light">
      <div class="container">
        <div class="section-title reveal">
          <h2>How It Works</h2>
          <p>A simple, stress-free process to get the care your family deserves.</p>
        </div>
        <div class="process-grid">
          <div class="process-item reveal">
            <span class="step-number">01</span>
            <h3>Initial Consultation</h3>
            <p>We speak with you to understand your baby's current routine and your specific needs.</p>
          </div>
          <div class="process-item reveal">
            <span class="step-number">02</span>
            <h3>Custom Care Plan</h3>
            <p>Kareen Barrett designs a personalized care or sleep training strategy for your family.</p>
          </div>
          <div class="process-item reveal">
            <span class="step-number">03</span>
            <h3>Dedicated Support</h3>
            <p>Our expert team begins the care journey, providing continuous support and guidance.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="testimonials section-padding">
      <div class="container">
        <div class="section-title reveal">
          <h2>From Our Families</h2>
          <p>Join the many Alberta families who have found peace of mind with us.</p>
        </div>
        <div class="testimonials-grid">
          <div class="testimonial-card reveal">
            <p>"Kareen was a lifesaver for our firstborn. Her gentle approach to sleep training worked wonders in just a week!"</p>
            <div class="author">- Sarah & James, Calgary</div>
          </div>
          <div class="testimonial-card reveal">
            <p>"Highly professional and incredibly nurturing. We felt 100% confident leaving our newborn in their hands."</p>
            <div class="author">- Michael T., Edmonton</div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="faq section-padding bg-light">
      <div class="container">
        <div class="section-title reveal">
          <h2>Common Questions</h2>
          <p>Everything you need to know about our nanny and newborn services.</p>
        </div>
        <div class="faq-list">
          <div class="faq-item reveal">
            <h3>Is Kareen Barrett involved in every case?</h3>
            <p>Yes, Kareen personally oversees every care plan and conducts initial consultations to ensure the highest standards.</p>
          </div>
          <div class="faq-item reveal">
            <h3>Do you provide overnight support?</h3>
            <p>Absolutely. We offer specialized overnight newborn care to help parents get the rest they need while ensuring the baby is safe and fed.</p>
          </div>
          <div class="faq-item reveal">
            <h3>How do payments work?</h3>
            <p>We handle all payments offline. A $25 scheduling fee is required to book, with the remainder settled via direct invoice.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA SECTION -->
    <section class="cta-section reveal section-padding">
      <div class="container">
        <div class="cta-box">
          <h2>Ready to give your baby the best care?</h2>
          <p>Schedule a consultation with Kareen Barrett today and experience the Toddler's Infantry difference.</p>
          <div class="cta-btn">
            <Button href="/contact" variant="secondary">Start Your Journey</Button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* HERO */
  .hero {
    padding: calc(var(--navbar-height) + var(--space-lg)) 0 var(--space-xl);
    background: linear-gradient(135deg, var(--color-secondary) 0%, #FFFFFF 100%);
    overflow: hidden;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-lg);
    align-items: center;
  }

  .hero-content h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    margin-bottom: var(--space-md);
    color: #000000;
    line-height: 1.1;
  }

  .text-accent {
    color: var(--color-primary);
  }

  .hero-content p {
    font-size: 1.25rem;
    color: #444;
    margin-bottom: var(--space-lg);
    max-width: 600px;
  }

  .hero-btns {
    display: flex;
    gap: var(--space-md);
  }

  .hero-image {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .image-wrapper {
    width: 100%;
    max-width: 500px;
    aspect-ratio: 1;
    background: var(--color-secondary);
    border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
    animation: blob 10s infinite alternate;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-img-main {
    width: 60%;
    height: auto;
    object-fit: contain;
  }

  @keyframes blob {
    0% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
    100% { border-radius: 70% 30% 30% 70% / 70% 70% 30% 30%; }
  }

  /* SERVICES PREVIEW */
  .services-preview {
    padding: var(--space-xl) 0;
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .section-title h2 {
    font-size: 3rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
    align-items: stretch;
  }

  .service-card {
    padding: var(--space-lg) var(--space-md);
    background: var(--color-secondary);
    border-radius: 30px;
    text-align: center;
    transition: transform 0.5s var(--transition-smooth);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 350px;
  }

  .service-card:hover {
    transform: translateY(-10px);
    background: white;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
  }

  .service-icon {
    font-size: 3rem;
    margin-bottom: var(--space-md);
  }

  /* GENERAL */
  .bg-light {
    background: var(--color-bg-light);
  }

  /* PROCESS */
  .process-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-xl);
    text-align: center;
  }

  .process-item {
    position: relative;
    padding: var(--space-lg);
  }

  .step-number {
    font-size: 5rem;
    font-family: var(--font-heading);
    color: var(--color-primary);
    opacity: 0.15;
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 0;
  }

  .process-item h3 {
    position: relative;
    z-index: 1;
    margin-bottom: var(--space-sm);
  }

  /* TESTIMONIALS */
  .testimonials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
  }

  .testimonial-card {
    background: white;
    padding: var(--space-lg);
    border-radius: 30px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    border-left: 4px solid var(--color-primary);
  }

  .testimonial-card p {
    font-style: italic;
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
  }

  .testimonial-card .author {
    font-weight: 600;
    color: var(--color-primary);
  }

  /* FAQ */
  .faq-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .faq-item {
    background: white;
    padding: var(--space-md) var(--space-lg);
    border-radius: 20px;
  }

  .faq-item h3 {
    font-size: 1.3rem;
    margin-bottom: 8px;
    color: var(--color-primary);
  }

  /* CTA SECTION */
  .cta-section {
    padding-bottom: var(--space-xl);
  }

  .cta-box {
    background: var(--color-primary); /* Deep Forest Sage */
    padding: var(--space-xl) var(--space-lg);
    border-radius: 40px;
    text-align: center;
    color: white;
    box-shadow: 0 30px 60px rgba(107, 124, 103, 0.25);
    position: relative;
    overflow: hidden;
  }

  .cta-box h2 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: white;
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .cta-box p {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-lg);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-btn {
    display: flex;
    justify-content: center;
  }

  /* MOBILE */
  @media (max-width: 992px) {
    .hero-container {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-content p {
      margin: 0 auto var(--space-lg);
    }
    .hero-btns {
      justify-content: center;
    }
    .hero-image {
      order: -1;
    }
    .testimonials-grid {
      grid-template-columns: 1fr;
    }
    .cta-box {
      padding: var(--space-lg) var(--space-md);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('astro:page-load', () => {
    // Hero Animations
    gsap.from('.animate-up', {
      y: 50,
      opacity: 0,
      duration: 1,
      stagger: 0.2,
      ease: 'power4.out'
    });

    gsap.from('.animate-fade', {
      opacity: 0,
      duration: 1.5,
      delay: 0.5,
      ease: 'power2.out'
    });

    // Reveal on Scroll
    const reveals = document.querySelectorAll('.reveal');
    
    // Hide initially via JS for animation
    gsap.set(reveals, { opacity: 0, y: 30 });

    reveals.forEach((el) => {
      gsap.to(el, {
        scrollTrigger: {
          trigger: el,
          start: 'top 90%',
        },
        y: 0,
        opacity: 1,
        duration: 1,
        ease: 'power3.out',
        clearProps: 'all' // Clean up after animation
      });
    });
  });
</script>
