---
interface FooterLink {
  label: string;
  url: string;
}

interface Props {
  logoUrl?: string;
  logoAlt?: string;
  tagline?: string;
  links?: FooterLink[];
  email?: string;
  phone?: string;
  location?: string;
  copyrightName?: string;
}

const {
  logoUrl,
  logoAlt = "Toddler's Infantry Logo",
  tagline = "Premium newborn and baby care services dedicated to nurturing your child's growth and happiness.",
  links = [
    { label: "Home", url: "/" },
    { label: "About Us", url: "/about" },
    { label: "Services", url: "/services" },
    { label: "Contact", url: "/contact" },
  ],
  email = "care@toddlersinfantry.com",
  phone = "(555) 123-4567",
  location = "Alberta, Canada",
  copyrightName = "Toddler's Infantry",
} = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img
          src={logoUrl || "/red-logo.svg"}
          alt={logoAlt}
          class="footer-logo theme-logo"
        />
        <p>{tagline}</p>
      </div>

      <div class="footer-links">
        <h3>Quick Links</h3>
        <ul>
          {
            links.map((link) => (
              <li>
                <a href={link.url}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-contact">
        <h3>Contact Info</h3>
        {email && <p>Email: {email}</p>}
        {phone && <p>Phone: {phone}</p>}
        {location && <p>Location: {location}</p>}
      </div>
    </div>

    <div class="footer-bottom">
      <p>
        &copy; {currentYear}
        {copyrightName}. All rights reserved. Designed and Developed by <a
          href="https://chameleon-ideas.com"
          target="_blank"
          rel="noopener noreferrer">Chameleon Ideas Inc.</a
        >
      </p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-secondary);
    padding: var(--space-xl) 0 var(--space-md);
    margin-top: var(--space-xl);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-xl);
  }

  .footer-logo {
    height: 140px;
    width: auto;
    margin-bottom: var(--space-md);
  }
  @media (max-width: 620px) {
    .footer-logo {
      height: 100px;
    }
  }

  .footer-brand p {
    max-width: 300px;
    color: #666;
  }

  h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  ul {
    list-style: none;
    padding: 0;
  }

  ul li {
    margin-bottom: var(--space-sm);
  }

  ul li a {
    text-decoration: none;
    color: #666;
    transition: color 0.3s ease;
  }

  ul li a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    padding-top: var(--space-md);
    text-align: center;
    color: #999;
    font-size: var(--text-sm);
    line-height: 1.8;
  }

  .footer-bottom a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .footer-bottom a:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }

  @media (max-width: 480px) {
    footer {
      padding: var(--space-lg) 0 var(--space-sm);
    }
    .footer-brand p {
      max-width: 100%;
    }
  }
</style>
