---
import { ClientRouter } from 'astro:transitions';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import '../styles/variables.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Toddler's Infantry - Professional Newborn and Baby Care Services" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@400;600;700&display=swap" rel="stylesheet">
    
    <ClientRouter />
  </head>
  <body>
    <slot />
    <ThemeSwitcher />

    <style is:global>
      :root {
        --navbar-height: 80px;
      }
      
      * {
        box-sizing: border-box;
      }

      html, body {
        scroll-behavior: auto !important; /* Required for Lenis */
        margin: 0;
        padding: 0;
        width: 100%;
        min-height: 100%;
      }

      body {
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Base state for animations: visible by default, JS will hide them to animate */
      .reveal {
        visibility: visible;
        opacity: 1;
      }

      /* Fallback for when JS is disabled or fails to load */
      .no-js .reveal {
        opacity: 1 !important;
        visibility: visible !important;
        transform: none !important;
      }
    </style>

    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      // Initialize Lenis
      const initLenis = () => {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          smoothTouch: false,
        });

        gsap.registerPlugin(ScrollTrigger);

        lenis.on('scroll', ScrollTrigger.update);

        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });

        gsap.ticker.lagSmoothing(0);
        
        return lenis;
      };

      // Handle page transitions
      let lenis: Lenis;
      
      document.addEventListener('astro:page-load', () => {
        lenis = initLenis();
        // Force scroll update on load
        ScrollTrigger.refresh();
      });

      document.addEventListener('astro:before-preparation', () => {
        if (lenis) lenis.destroy();
      });

      // Global GSAP fail-safe
      window.addEventListener('load', () => {
        setTimeout(() => {
          const reveals = document.querySelectorAll('.reveal');
          reveals.forEach(el => {
            if (getComputedStyle(el).opacity === '0') {
              (el as HTMLElement).style.opacity = '1';
              (el as HTMLElement).style.visibility = 'visible';
            }
          });
        }, 3000); // 3-second safety net
      });
    </script>
  </body>
</html>
